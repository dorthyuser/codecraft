{
  "name": "codecraft",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node backend/index.js\" --names \"UI,API\" --prefix-colors \"cyan,green\"",
    "dev:ui": "vite",
    "dev:api": "node backend/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "install:all": "npm install && cd backend && npm install"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "vite": "^5.4.10"
  }
}
